# TrueFoundry — AI Gateway
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_TENANT_URL=https://gateway.truefoundry.ai

# TrueFoundry — MCP Gateway (get from platform.truefoundry.cloud → MCP Gateway)
TFY_MCP_GATEWAY_URL=
TFY_MCP_GATEWAY_KEY=

# MCP Server secret — TrueFoundry presents this on every inbound tool call
# Set to any strong random string, then enter same value in TrueFoundry dashboard
MCP_SERVER_SECRET=

# TrueFoundry — Guardrails (get from platform.truefoundry.cloud → AI Gateway → Guardrails)
TFY_GUARDRAIL_INPUT_ID=
TFY_GUARDRAIL_OUTPUT_ID=

# AWS Bedrock (via TrueFoundry AI Gateway)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=deaddrop
MYSQL_USER=deaddrop
MYSQL_PASSWORD=

# App
API_PORT=8000
LOG_LEVEL=INFO
# Enable scenario + chaos injection endpoints (hackathon demo only)
DEMO_MODE=true
# Max seconds for deploy step before retry/fail (prevents stuck DEPLOYING in demos)
DEPLOY_STEP_TIMEOUT_S=90

# Optional: real Slack alert when notifier runs (scenarios C/D — impresses judges)
SLACK_WEBHOOK_URL=
